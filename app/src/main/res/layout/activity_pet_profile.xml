<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/accent"
        app:title="Профиль питомца"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_back" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/image_profile_pet"
                android:layout_width="300dp"
                android:layout_height="300dp"
                android:layout_marginTop="16dp"
                android:layout_gravity="center"
                android:src="@drawable/pet_care_18769509"
                android:scaleType="centerCrop"
                android:background="@drawable/rounded_photo" />

            <TextView
                android:id="@+id/text_profile_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Мурка"
                android:textColor="@color/titleColor"
                android:textSize="24sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp" />

            <TextView
                android:id="@+id/text_profile_type_age"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Кошка, 3 года"
                android:textColor="@color/textColor"
                android:layout_marginTop="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:background="@color/white"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Информация"
                    android:textColor="@color/titleColor"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/text_profile_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Вид: "
                    android:textColor="@color/black"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/text_profile_gender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Пол: "
                    android:textColor="@color/black"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/text_profile_birthdate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Дата рождения: "
                    android:textColor="@color/black"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/text_profile_breed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Порода: "
                    android:textColor="@color/black"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/text_profile_color"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Окрас: "
                    android:textColor="@color/black"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/text_profile_weight"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Вес: "
                    android:textColor="@color/black"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/text_profile_chip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Чип: "
                    android:textColor="@color/black"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/text_profile_food"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Корм: "
                    android:textColor="@color/black"
                    android:layout_marginTop="8dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:background="@color/white"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Примечания"
                    android:textColor="@color/titleColor"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/text_profile_notes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="@color/textColor"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:spacing="16dp">

        <Button
            android:id="@+id/button_edit_pet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Изменить"
            android:backgroundTint="@color/accent"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/button_delete_pet"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Удалить"
            android:backgroundTint="#FF6B6B"
            android:textColor="@color/white"
            android:layout_marginStart="16dp" />
    </LinearLayout>
</LinearLayout>
