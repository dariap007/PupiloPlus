<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/accent"
        app:title="Добавление напоминания"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_back" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <EditText
                android:id="@+id/edit_reminder_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Название"
                android:layout_marginTop="16dp"
                android:background="@drawable/edit_text_background"
                android:textColor="@color/textColor"
                android:textColorHint="@color/secondary" />

            <Spinner
                android:id="@+id/spinner_reminder_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/edit_text_background"
                android:popupBackground="@color/white" />

            <EditText
                android:id="@+id/edit_custom_reminder_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Другой вид напоминания"
                android:layout_marginTop="12dp"
                android:background="@drawable/edit_text_background"
                android:textColor="@color/textColor"
                android:textColorHint="@color/secondary"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Выберите питомцев"
                android:textColor="@color/black"
                android:layout_marginTop="12dp" />

            <LinearLayout
                android:id="@+id/layout_pet_selection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/text_reminder_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Дата напоминания"
                android:padding="14dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edit_text_background"
                android:textColor="@color/accent"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/text_reminder_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Время напоминания"
                android:padding="14dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/edit_text_background"
                android:textColor="@color/accent"
                android:clickable="true"
                android:focusable="true" />

            <Spinner
                android:id="@+id/spinner_frequency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/edit_text_background"
                android:popupBackground="@color/white" />

            <LinearLayout
                android:id="@+id/layout_days_of_week"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:visibility="gone" />

            <EditText
                android:id="@+id/edit_reminder_notes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Примечание"
                android:layout_marginTop="12dp"
                android:background="@drawable/edit_text_background"
                android:textColor="@color/textColor"
                android:textColorHint="@color/secondary"
                android:minLines="3" />

            <Button
                android:id="@+id/button_save_reminder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Сохранить"
                android:backgroundTint="@color/accent"
                android:textColor="@color/white"
                android:layout_marginTop="18dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
