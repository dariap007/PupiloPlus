<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    card_view:cardCornerRadius="16dp"
    card_view:cardBackgroundColor="@color/white"
    card_view:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/image_reminder"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:src="@drawable/ic_reminder"
            android:tint="@color/accent"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text_reminder_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Кормление"
                android:textColor="@color/titleColor"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/text_reminder_details"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Собака • 10:00 01.05.2026"
                android:textColor="@color/textColor"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/text_reminder_period"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Каждый день"
                android:textColor="@color/secondary"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/text_reminder_dose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="150 г"
                android:textColor="@color/secondary"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
